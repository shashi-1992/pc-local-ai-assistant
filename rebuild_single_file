"""Parse Google Chat HTTP events and produce reply text."""

from __future__ import annotations

import logging
import re
from typing import Any

from app.config import settings
from app.services.chat_agent import answer_with_tools
from app.services.rag import answer_query

logger = logging.getLogger(__name__)

_MENTION = re.compile(r"^<users/[^>]+>\s*")


def _allowed_space(space_name: str) -> bool:
    raw = (settings.google_chat_allowed_spaces or "").strip()
    if not raw:
        return True
    allowed = {s.strip() for s in raw.split(",") if s.strip()}
    return space_name in allowed


def _strip_mentions(text: str) -> str:
    t = _MENTION.sub("", text)
    return t.strip()


def handle_google_chat_event(payload: dict[str, Any]) -> dict[str, str]:
    """
    Return a Google Chat response object, e.g. {"text": "..."}.
    https://developers.google.com/chat/api/guides/message-formats/basic
    """
    typ = str(payload.get("type") or payload.get("eventType") or "").upper()

    if typ in ("ADDED_TO_SPACE", "ADDED_TO_DM"):
        return {
            "text": (
                "Local AI Assistant is connected.\n"
                "I answer from your ingested knowledge base (RAG). "
                "Use the REST API flag for tools (Jira/Bitbucket) if enabled.\n"
                "Say *help* for tips."
            )
        }

    if typ in ("REMOVED_FROM_SPACE", "REMOVED_FROM_DM"):
        return {"text": ""}

    if typ != "MESSAGE":
        logger.info("Ignoring Google Chat event type=%s", typ)
        return {"text": ""}

    msg = payload.get("message") or {}
    raw_text = (msg.get("text") or "").strip()
    text = _strip_mentions(raw_text)
    space_name = (payload.get("space") or {}).get("name") or ""

    if space_name and not _allowed_space(space_name):
        return {"text": "This Chat space is not on the allowlist for this deployment."}

    if not text:
        return {"text": "Send a text message (or type *help*)."}

    low = text.lower()
    if low in ("help", "help!", "/help"):
        return {
            "text": (
                "*Commands*\n"
                "• Ask any question — I search your indexed docs (RAG).\n"
                "• Prefix with `!tools ` to use Jira/Bitbucket tools (if configured).\n"
                "• API: `POST /v1/chat` with `use_tools` for the same agent.\n"
                "Docs: see `docs/GOOGLE_CHAT.md` in the repo."
            )
        }

    use_tools = text.lower().startswith("!tools ")
    if use_tools:
        text = text[7:].strip() or "What tools are available?"

    try:
        if use_tools and settings.google_chat_use_tools:
            reply = answer_with_tools(text)
        else:
            reply = answer_query(text)
    except Exception as e:
        logger.exception("Google Chat handler error")
        reply = f"Error: {e!s}"

    # Chat message length limits — trim safely
    if len(reply) > 4000:
        reply = reply[:3990] + "\n…(truncated)"
    return {"text": reply}
