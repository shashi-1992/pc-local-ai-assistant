## File: `scripts/extract_rebuild_kit.py`

```text
#!/usr/bin/env python3
"""
Extract files from docs/REBUILD_SINGLE_FILE.md into the current directory tree.

Use this instead of copy-pasting from Markdown preview (preview often breaks fences
and line endings). Run from project root:

  python3 scripts/extract_rebuild_kit.py
  python3 scripts/extract_rebuild_kit.py --dry-run
"""
from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
DEFAULT_MD = ROOT / "docs" / "REBUILD_SINGLE_FILE.md"


def extract(md_path: Path, dest_root: Path, dry_run: bool) -> int:
    text = md_path.read_text(encoding="utf-8")
    lines = text.splitlines(keepends=True)

    i = 0
    written = 0
    n = len(lines)

    while i < n:
        m = re.match(r"^## File: `([^`]+)`\s*$", lines[i].rstrip("\n"))
        if not m:
            i += 1
            continue
        rel = m.group(1)
        i += 1
        # skip blank lines
        while i < n and lines[i].strip() == "":
            i += 1
        if i >= n or not lines[i].lstrip().startswith("```"):
            print(f"Warning: no opening fence after ## File: `{rel}`", file=sys.stderr)
            continue
        i += 1  # skip opening fence
        buf: list[str] = []
        while i < n:
            line = lines[i]
            if line.rstrip("\n").strip() == "```" and not buf:
                # empty file
                i += 1
                break
            if line.rstrip("\n").strip() == "```":
                i += 1
                break
            buf.append(line)
            i += 1

        out = dest_root / rel
        content = "".join(buf)
        # normalize trailing newline
        if content and not content.endswith("\n"):
            content += "\n"

        if dry_run:
            print(f"would write {out} ({len(content)} bytes)")
        else:
            out.parent.mkdir(parents=True, exist_ok=True)
            out.write_text(content, encoding="utf-8")
            if rel.endswith(".sh"):
                try:
                    out.chmod(out.stat().st_mode | 0o111)
                except OSError:
                    pass
            print(f"wrote {rel}")
        written += 1

    print(f"Done. {written} file(s).")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(description="Extract REBUILD_SINGLE_FILE.md to disk.")
    ap.add_argument(
        "--md",
        type=Path,
        default=DEFAULT_MD,
        help="Path to REBUILD_SINGLE_FILE.md",
    )
    ap.add_argument(
        "--dest",
        type=Path,
        default=ROOT,
        help="Root directory to write paths under (default: repo root)",
    )
    ap.add_argument("--dry-run", action="store_true")
    args = ap.parse_args()

    if not args.md.is_file():
        print(f"Not found: {args.md}", file=sys.stderr)
        return 1

    return extract(args.md, args.dest, args.dry_run)


if __name__ == "__main__":
    raise SystemExit(main())
```

