"""Shared httpx settings for Jira / Bitbucket / Confluence (TLS + proxy behavior)."""

from __future__ import annotations

import logging
import ssl
from typing import Any

import httpx

from app.config import settings

logger = logging.getLogger(__name__)


def _insecure_ssl_context() -> ssl.SSLContext:
    """Explicit no-verify context (more reliable across httpx/OpenSSL than verify=False alone)."""
    ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_CLIENT)
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    return ctx


def atlassian_httpx_client_kwargs(timeout: float = 30.0) -> dict[str, Any]:
    """
    - ATLASSIAN_CA_BUNDLE set → verify=path to PEM.
    - Else ATLASSIAN_HTTP_VERIFY=false → insecure SSLContext + trust_env=False (ignores HTTP_PROXY;
      corporate proxies often break TLS even when verify is off).
    - Else → verify=True, trust_env from ATLASSIAN_HTTPX_TRUST_ENV.
    """
    bundle = (settings.atlassian_ca_bundle or "").strip()
    if bundle:
        verify: bool | ssl.SSLContext | str = bundle
        trust_env = settings.atlassian_http_trust_env
    elif not settings.atlassian_http_verify:
        verify = _insecure_ssl_context()
        # Must ignore HTTP(S)_PROXY for many corporate setups; otherwise MITM proxy still fails.
        trust_env = False
        logger.warning(
            "Atlassian TLS: using insecure SSL context + trust_env=False "
            "(ATLASSIAN_HTTP_VERIFY=false). Not for production."
        )
    else:
        verify = True
        trust_env = settings.atlassian_http_trust_env

    return {"timeout": timeout, "verify": verify, "trust_env": trust_env}


def atlassian_httpx_Client(timeout: float = 30.0) -> httpx.Client:
    return httpx.Client(**atlassian_httpx_client_kwargs(timeout=timeout))


def atlassian_httpx_insecure_plain_client(timeout: float = 30.0) -> httpx.Client:
    """Last-resort client: verify=False + trust_env=False (no SSLContext object)."""
    return httpx.Client(timeout=timeout, verify=False, trust_env=False)


def jira_post_json_ssl_unverified(url: str, payload: dict, auth: tuple[str, str]) -> tuple[int, bytes]:
    """
    Final fallback for stubborn TLS: stdlib urllib + ssl._create_unverified_context().
    Returns (status_code, response_body).
    """
    import base64
    import json as json_lib
    import urllib.error
    import urllib.request

    data = json_lib.dumps(payload).encode("utf-8")
    req = urllib.request.Request(url, data=data, method="POST")
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    token = base64.b64encode(f"{auth[0]}:{auth[1]}".encode()).decode()
    req.add_header("Authorization", f"Basic {token}")
    ctx = ssl._create_unverified_context()
    try:
        with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:
            return resp.status, resp.read()
    except urllib.error.HTTPError as e:
        return e.code, e.read()
