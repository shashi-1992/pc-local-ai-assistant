def _is_likely_ssl_error_chain(exc: BaseException | None) -> bool:
    """Walk exception graph — httpx may put SSLError in __context__ while __cause__ is set elsewhere."""
    seen: set[int] = set()
    stack: list[BaseException | None] = [exc]
    while stack and len(seen) < 32:
        cur = stack.pop()
        if cur is None or id(cur) in seen:
            continue
        seen.add(id(cur))
        if _is_likely_ssl_error(cur):
