                raw = body.get("value") or ""
                text = _strip_html(raw) if raw else ""
                safe_title = re.sub(r"[^\w\s-]", "", title)[:80].strip() or "page"
                fname = f"{pid}_{safe_title.replace(' ', '_')}.md"
                path = out_dir / fname
                header = f"# {title}\n\n<!-- confluence_id={pid} space={space_key} -->\n\n"
                path.write_text(header + text, encoding="utf-8")
                written.append(path)
                logger.info("wrote %s", path.name)
            if len(results) < limit:
                break
            start += limit

