    if isinstance(exc, ssl.SSLError):
        return True
    n = type(exc).__name__.lower()
    if "ssl" in n or "tls" in n:
        return True
    msg = (str(exc) + " " + repr(exc)).lower()
    return any(
        k in msg
        for k in (
            "ssl",
            "tls",
            "certificate",
            "cert verify",
            "certificate_verify_failed",
            "hostname",
            "verification",
            "openssl",
            "handshake",
            "unexpected_eof",
            "eof occurred",
