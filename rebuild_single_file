def _retrieval_pairs(
    retrieval_query: str,
) -> tuple[list[tuple[str, dict, float]], bool]:
    """Chroma retrieval after distance filter. Second value: True if Chroma returned any document row."""
    q_emb = embed_query(retrieval_query)
    col = get_collection()
    n = min(settings.retrieve_top_k, max(1, collection_count()))
    res = col.query(
        query_embeddings=[q_emb],
        n_results=n,
        include=["documents", "metadatas", "distances"],
    )
    docs = (res.get("documents") or [[]])[0]
    metas = (res.get("metadatas") or [[]])[0]
    dists = (res.get("distances") or [[]])[0]

    if not docs:
        return [], False

    pairs: list[tuple[str, dict, float]] = []
    for i, doc in enumerate(docs):
        d = dists[i] if i < len(dists) else 0.0
        meta = metas[i] if i < len(metas) else {}
        if settings.retrieve_max_distance is not None and d > settings.retrieve_max_distance:
            continue
        pairs.append((doc, meta if isinstance(meta, dict) else {}, float(d)))
    return pairs, True


def _format_context_from_pairs(pairs: list[tuple[str, dict, float]]) -> str:
    context_blocks = []
    for doc, meta, _ in pairs:
        src = meta.get("source", "unknown")
        context_blocks.append(f"---\nSource: {src}\n{doc}\n")
    return "\n".join(context_blocks)


def sources_from_pairs(pairs: list[tuple[str, dict, float]], excerpt_max: int = 1200) -> list[dict[str, Any]]:
    """Structured chunks for API/UI (Confluence export paths show up as `source`)."""
    out: list[dict[str, Any]] = []
    for doc, meta, d in pairs[:12]:
        ex = doc if len(doc) <= excerpt_max else doc[:excerpt_max] + "…"
        out.append(
