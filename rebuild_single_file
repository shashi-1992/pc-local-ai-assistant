        return (
            "[Config] Set OPENAI_API_KEY (cloud) or OPENAI_BASE_URL (local LLM, e.g. Ollama) — docs/LOCAL_LLM.md. "
            "Then run: cd backend && python -m app.cli_ingest",
            [],
            "config",
