"""PHASE_1: Chunk, embed, upsert into Chroma."""

from __future__ import annotations

import hashlib
import logging
from pathlib import Path

from app.config import settings
from app.services.chroma_store import get_collection
from app.services.embeddings import embed_texts

logger = logging.getLogger(__name__)

MAX_CHUNK_CHARS = 1200
OVERLAP_CHARS = 150


def _chunk_text(text: str, source_id: str) -> list[tuple[str, str]]:
    """Return list of (chunk_id, chunk_text) using sliding windows."""
    text = text.strip()
    if not text:
        return []
    chunks: list[tuple[str, str]] = []
    i = 0
    idx = 0
    while i < len(text):
        piece = text[i : i + MAX_CHUNK_CHARS].strip()
        if not piece:
            break
        cid = _chunk_hash(source_id, idx, piece)
        chunks.append((cid, piece))
        idx += 1
        i += max(1, MAX_CHUNK_CHARS - OVERLAP_CHARS)
    return chunks


def _chunk_hash(source_id: str, idx: int, content: str) -> str:
    h = hashlib.sha256(f"{source_id}:{idx}:{content}".encode()).hexdigest()[:24]
    return f"{source_id}:{idx}:{h}"


def ingest_file(path: Path, source_id: str | None = None) -> int:
    """Ingest one text/markdown file. Returns number of chunks added."""
    sid = source_id or path.name
    text = path.read_text(encoding="utf-8", errors="replace")
    pairs = _chunk_text(text, sid)
    if not pairs:
        return 0
    ids = [p[0] for p in pairs]
    documents = [p[1] for p in pairs]
    embeddings = embed_texts(documents)
    col = get_collection()
    col.upsert(
        ids=ids,
        embeddings=embeddings,
        documents=documents,
        metadatas=[{"source": sid, "path": str(path)} for _ in ids],
    )
    logger.info("ingested %s chunks from %s", len(ids), path)
    return len(ids)


def ingest_directory(directory: Path | None = None) -> dict[str, int]:
    """Ingest all `.md` and `.txt` files under directory. Returns stats per file."""
    root = directory or settings.knowledge_dir
    root = root.resolve()
    if not root.is_dir():
        logger.warning("knowledge directory does not exist: %s", root)
        return {}
    stats: dict[str, int] = {}
    for pattern in ("**/*.md", "**/*.txt"):
        for path in root.glob(pattern):
            if path.is_file():
                n = ingest_file(path, source_id=str(path.relative_to(root)))
                stats[str(path.relative_to(root))] = n
