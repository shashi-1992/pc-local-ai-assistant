    written: list[Path] = []
    start = 0
    limit = 25
    auth = (user, token)
    headers = {"Accept": "application/json"}
    with atlassian_httpx_Client(timeout=60.0) as client:
        while True:
            r = client.get(
                api,
                auth=auth,
                headers=headers,
                params={
